generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  retailer_admin
  super_admin
}

enum FitPreference {
  slim
  regular
  relaxed
}

enum MeasurementsSource {
  manual
  ai_estimated
  mediapipe
}

enum BodyType {
  hourglass
  pear
  apple
  rectangle
  inverted_triangle
}

enum StorePlan {
  free
  starter
  growth
  enterprise
}

enum GarmentType {
  top
  bottom
  dress
  outerwear
  accessory
}

enum GenderType {
  mens
  womens
  unisex
  kids
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum TryOnStatus {
  queued
  processing
  completed
  failed
}

enum RecommendationSessionType {
  try_on_followup
  proactive
  user_requested
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String?
  avatarUrl   String?
  phone       String?
  role        UserRole  @default(customer)
  isActive    Boolean   @default(true)
  isVerified  Boolean   @default(false)
  supabaseId  String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bodyProfile      BodyProfile?
  styleProfile     StyleProfile?
  stores           Store[]
  cartItems        CartItem[]
  orders           Order[]
  tryOnResults     TryOnResult[]
  wardrobeItems    WardrobeItem[]
  recommendations  StyleRecommendation[]
  wishlists        Wishlist[]
}

model BodyProfile {
  id                 String              @id @default(uuid())
  userId             String              @unique
  heightCm           Float?
  weightKg           Float?
  bustCm             Float?
  waistCm            Float?
  hipsCm             Float?
  shoulderWidthCm    Float?
  inseamCm           Float?
  bodyType           BodyType?
  skinTone           String?
  fitPreference      FitPreference?
  styleTags          String[]
  photoUrl           String?
  measurementsSource MeasurementsSource?
  updatedAt          DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StyleProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  preferredStyles String[]
  occasions       String[]
  colorPalette    String[]
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Brand & Store ────────────────────────────────────────────────────────────

model Brand {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logo           String?
  commissionRate Decimal  @default(0.10) @db.Decimal(5, 4)
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())

  products Product[]
}

model Store {
  id              String    @id @default(uuid())
  ownerId         String
  name            String
  slug            String    @unique
  logoUrl         String?
  domain          String?
  stripeAccountId String?
  plan            StorePlan @default(free)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  owner    User      @relation(fields: [ownerId], references: [id])
  products Product[]
  orders   Order[]
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id       String    @id @default(uuid())
  storeId  String?
  parentId String?
  name     String
  slug     String

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]
}

model Product {
  id              String       @id @default(uuid())
  storeId         String
  brandId         String?
  categoryId      String?
  name            String
  slug            String
  description     String?
  price           Decimal      @db.Decimal(10, 2)
  currency        String       @default("NPR")
  sizes           String[]
  gender          GenderType?
  garmentType     GarmentType?
  tags            String[]
  isActive        Boolean      @default(true)
  isTryonEnabled  Boolean      @default(false)
  flatLayImageUrl String?
  modelImageUrl   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  store         Store            @relation(fields: [storeId], references: [id])
  brand         Brand?           @relation(fields: [brandId], references: [id])
  category      Category?        @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]
  tryOnResults  TryOnResult[]
  orderItems    OrderItem[]
  wardrobeItems WardrobeItem[]
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String
  size          String?
  color         String?
  colorHex      String?
  sku           String? @unique
  stockQuantity Int     @default(0)
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  imageUrl      String?

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  wishlists  Wishlist[]
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  variantId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  userId          String
  storeId         String
  status          OrderStatus @default(pending)
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("NPR")
  paymentMethod   String?
  paymentRef      String?     @unique
  shippingAddress Json?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  store Store       @relation(fields: [storeId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  productId    String
  productName  String
  size         String?
  quantity     Int
  priceAtTime  Decimal  @db.Decimal(10, 2)
  totalPrice   Decimal  @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Try-On ───────────────────────────────────────────────────────────────────

model TryOnResult {
  id                    String      @id @default(uuid())
  userId                String?
  productId             String
  userPhotoUrl          String
  garmentImageUrl       String
  resultImageUrl        String?
  sizeRecommended       String?
  replicatePredictionId String?
  status                TryOnStatus @default(queued)
  processingTimeMs      Int?
  bodyMeasurements      Json?
  errorMessage          String?
  createdAt             DateTime    @default(now())

  user          User?          @relation(fields: [userId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  wardrobeItems WardrobeItem[]
}

// ─── Wardrobe ─────────────────────────────────────────────────────────────────

model WardrobeItem {
  id            String   @id @default(uuid())
  userId        String
  productId     String
  tryOnResultId String?
  savedAt       DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  tryOnResult TryOnResult? @relation(fields: [tryOnResultId], references: [id])

  @@unique([userId, productId])
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  variantId String
  addedAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
}

// ─── Recommendations ──────────────────────────────────────────────────────────

model StyleRecommendation {
  id                  String                    @id @default(uuid())
  userId              String
  sessionType         RecommendationSessionType @default(user_requested)
  promptUsed          String?
  claudeResponse      Json?
  productIdsSuggested String[]
  userRating          Int?
  createdAt           DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id])
}
