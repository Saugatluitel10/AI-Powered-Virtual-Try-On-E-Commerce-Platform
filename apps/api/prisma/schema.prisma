generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatarUrl     String?
  supabaseId    String         @unique
  createdAt     DateTime       @default(now())
  bodyProfile   BodyProfile?
  styleProfile  StyleProfile?
  orders        Order[]
  wardrobeItems WardrobeItem[]
  tryOnResults  TryOnResult[]
}

model BodyProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  height    Float?
  weight    Float?
  bust      Float?
  waist     Float?
  hips      Float?
  shoulders Float?
  bodyType  String?
  photoUrl  String?
  updatedAt DateTime @updatedAt
}

model StyleProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  preferredStyles String[]
  occasions       String[]
  colorPalette    String[]
  updatedAt       DateTime @updatedAt
}

model Brand {
  id             String    @id @default(cuid())
  name           String
  logo           String?
  commissionRate Float     @default(0.10)
  isVerified     Boolean   @default(false)
  products       Product[]
}

model Product {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  brandId       String
  brand         Brand          @relation(fields: [brandId], references: [id])
  price         Float
  currency      String         @default("NPR")
  sizes         String[]
  category      String
  images        String[]
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  tryOnResults  TryOnResult[]
  orderItems    OrderItem[]
  wardrobeItems WardrobeItem[]
}

model TryOnResult {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  resultImageUrl  String?
  sizeRecommended String?
  sizeReasoning   String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        String      @default("pending")
  totalAmount   Float
  currency      String      @default("NPR")
  paymentMethod String?
  paymentRef    String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  size        String
  quantity    Int
  priceAtTime Float
}

model WardrobeItem {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  tryOnResultId String?
  savedAt       DateTime @default(now())
}
