generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BodyType {
  HOURGLASS
  PEAR
  APPLE
  RECTANGLE
  INVERTED_TRIANGLE
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  avatarUrl           String?
  supabaseId          String               @unique
  createdAt           DateTime             @default(now())
  bodyProfile         BodyProfile?
  styleProfile        StyleProfile?
  orders              Order[]
  cartItems           CartItem[]
  wardrobeItems       WardrobeItem[]
  tryOnResults        TryOnResult[]
  conversations       Conversation[]
  wardrobeCollections WardrobeCollection[]
}

model BodyProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  height    Float?
  weight    Float?
  bust      Float?
  waist     Float?
  hips      Float?
  shoulders Float?
  bodyType  BodyType?
  photoUrl  String?
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model StyleProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  preferredStyles String[]
  occasions       String[]
  colorPalette    String[]
  quizCompleted   Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Brand {
  id             String      @id @default(cuid())
  name           String
  logo           String?
  commissionRate Float       @default(0.10)
  isVerified     Boolean     @default(false)
  products       Product[]
  sizeCharts     SizeChart[]
}

model SizeChart {
  id        String @id @default(cuid())
  brandId   String
  brand     Brand  @relation(fields: [brandId], references: [id])
  size      String
  bustMin   Float?
  bustMax   Float?
  waistMin  Float?
  waistMax  Float?
  hipsMin   Float?
  hipsMax   Float?
  sortOrder Int    @default(0)

  @@unique([brandId, size])
  @@index([brandId])
}

model Product {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  brandId           String
  brand             Brand          @relation(fields: [brandId], references: [id])
  price             Float
  currency          String         @default("NPR")
  sizes             String[]
  category          String
  garmentType       String?
  gender            String?
  isTryonEnabled    Boolean        @default(false)
  suitableBodyTypes String[]
  images            String[]
  description       String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  tryOnResults      TryOnResult[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wardrobeItems     WardrobeItem[]

  @@index([brandId])
  @@index([category])
  @@index([garmentType])
  @@index([gender])
  @@index([isTryonEnabled])
  @@index([isActive])
}

model TryOnResult {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  userPhotoUrl     String?
  garmentImageUrl  String?
  resultImageUrl   String?
  predictionId     String?
  sizeRecommended  String?
  sizeReasoning    String?
  status           String   @default("pending")
  processingTimeMs Int?
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@index([status])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  size      String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, productId, size])
  @@index([userId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("pending")
  totalAmount     Float
  currency        String      @default("NPR")
  paymentMethod   String?
  paymentRef      String?
  shippingAddress Json?
  items           OrderItem[]
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  size        String
  quantity    Int
  priceAtTime Float

  @@index([orderId])
  @@index([productId])
}

model WardrobeItem {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  tryOnResultId String?
  collectionId  String?
  collection    WardrobeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  savedAt       DateTime            @default(now())

  @@index([userId])
  @@index([productId])
  @@index([collectionId])
}

model WardrobeCollection {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  name       String
  shareToken String?        @unique
  isPublic   Boolean        @default(false)
  items      WardrobeItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
  @@index([shareToken])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
