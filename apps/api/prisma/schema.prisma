generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  BRAND
  ADMIN
}

enum BodyType {
  HOURGLASS
  PEAR
  APPLE
  RECTANGLE
  INVERTED_TRIANGLE
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  avatarUrl           String?
  supabaseId          String               @unique
  role                Role                 @default(CUSTOMER)
  brandId             String?
  brand               Brand?               @relation("BrandMembers", fields: [brandId], references: [id])
  emailMarketing      Boolean              @default(true)
  emailOrders         Boolean              @default(true)
  emailTryOn          Boolean              @default(true)
  pushEnabled         Boolean              @default(false)
  createdAt           DateTime             @default(now())
  bodyProfile         BodyProfile?
  styleProfile        StyleProfile?
  orders              Order[]
  cartItems           CartItem[]
  wardrobeItems       WardrobeItem[]
  tryOnResults        TryOnResult[]
  conversations       Conversation[]
  wardrobeCollections WardrobeCollection[]
  returnRequests      ReturnRequest[]
  addresses           Address[]
  priceAlerts         PriceAlert[]
  brandFollows        BrandFollow[]
  reviews             Review[]
  notifications       Notification[]
  wishlistItems       WishlistItem[]
}

model BodyProfile {
  id                   String               @id @default(cuid())
  userId               String               @unique
  user                 User                 @relation(fields: [userId], references: [id])
  height               Float?
  weight               Float?
  bust                 Float?
  waist                Float?
  hips                 Float?
  shoulders            Float?
  bodyType             BodyType?
  photoUrl             String?
  overallConfidence     Float?
  heightConfidence      Float?
  bustConfidence        Float?
  waistConfidence       Float?
  hipsConfidence        Float?
  shouldersConfidence   Float?
  updatedAt            DateTime             @updatedAt
  measurementHistory   MeasurementHistory[]

  @@index([userId])
}

model MeasurementHistory {
  id            String      @id @default(cuid())
  bodyProfileId String
  bodyProfile   BodyProfile @relation(fields: [bodyProfileId], references: [id], onDelete: Cascade)
  height        Float?
  weight        Float?
  bust          Float?
  waist         Float?
  hips          Float?
  shoulders     Float?
  bodyType      BodyType?
  source        String      @default("ai_estimated")
  createdAt     DateTime    @default(now())

  @@index([bodyProfileId, createdAt])
}

model StyleProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  preferredStyles String[]
  occasions       String[]
  colorPalette    String[]
  quizCompleted   Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Brand {
  id             String        @id @default(cuid())
  name           String
  logo           String?
  commissionRate Float         @default(0.10)
  isVerified     Boolean       @default(false)
  products       Product[]
  sizeCharts     SizeChart[]
  members        User[]        @relation("BrandMembers")
  followers      BrandFollow[]
}

model SizeChart {
  id        String @id @default(cuid())
  brandId   String
  brand     Brand  @relation(fields: [brandId], references: [id])
  size      String
  bustMin   Float?
  bustMax   Float?
  waistMin  Float?
  waistMax  Float?
  hipsMin   Float?
  hipsMax   Float?
  sortOrder Int    @default(0)

  @@unique([brandId, size])
  @@index([brandId])
}

model Product {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  brandId           String
  brand             Brand          @relation(fields: [brandId], references: [id])
  price             Float
  currency          String         @default("NPR")
  sizes             String[]
  category          String
  garmentType       String?
  gender            String?
  isTryonEnabled    Boolean        @default(false)
  suitableBodyTypes String[]
  images            String[]
  description       String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  tryOnResults      TryOnResult[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wardrobeItems     WardrobeItem[]
  priceAlerts       PriceAlert[]
  reviews           Review[]
  variants          ProductVariant[]
  wishlistItems     WishlistItem[]

  @@index([brandId])
  @@index([category])
  @@index([garmentType])
  @@index([gender])
  @@index([isTryonEnabled])
  @@index([isActive])
}

model TryOnResult {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  userPhotoUrl     String?
  garmentImageUrl  String?
  resultImageUrl   String?
  predictionId     String?
  sizeRecommended  String?
  sizeReasoning    String?
  status           String         @default("pending")
  processingTimeMs Int?
  errorMessage     String?
  qualityRating    Int?
  createdAt        DateTime       @default(now())
  wardrobeItems    WardrobeItem[]

  @@index([userId])
  @@index([productId])
  @@index([status])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  size      String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, productId, size])
  @@index([userId])
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  status          String          @default("pending")
  totalAmount     Float
  discountAmount  Float           @default(0)
  currency        String          @default("NPR")
  paymentMethod   String?
  paymentRef      String?
  refundAmount    Float?
  refundRef       String?
  trackingNumber  String?
  discountCodeId  String?
  discountCode    DiscountCode?   @relation(fields: [discountCodeId], references: [id])
  shippingAddress Json?
  items           OrderItem[]
  returnRequests  ReturnRequest[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  size        String
  quantity    Int
  priceAtTime Float

  @@index([orderId])
  @@index([productId])
}

model WardrobeItem {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  tryOnResultId String?
  tryOnResult   TryOnResult?        @relation(fields: [tryOnResultId], references: [id], onDelete: SetNull)
  collectionId  String?
  collection    WardrobeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  savedAt       DateTime            @default(now())

  @@index([userId])
  @@index([productId])
  @@index([collectionId])
}

model WardrobeCollection {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  name       String
  shareToken String?        @unique
  isPublic   Boolean        @default(false)
  items      WardrobeItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
  @@index([shareToken])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model ReturnRequest {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  items     Json
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
}

// ─── Reviews & Ratings ───────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId   String?
  rating    Int
  title     String?
  comment   String?
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@index([userId])
}

// ─── Product Variants (Inventory) ────────────────────────────────────────────

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  stock     Int     @default(0)

  @@unique([productId, size])
  @@index([productId])
}

// ─── In-App Notifications ────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Address Book ────────────────────────────────────────────────────────────

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("Home")
  fullName  String
  phone     String
  street    String
  city      String
  district  String
  province  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Discount / Promo Codes ──────────────────────────────────────────────────

model DiscountCode {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String?
  discountType   String   @default("percentage")
  discountValue  Float
  minOrderAmount Float?
  maxUses        Int?
  currentUses    Int      @default(0)
  isActive       Boolean  @default(true)
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  orders         Order[]

  @@index([code])
}

// ─── Wishlist ────────────────────────────────────────────────────────────────

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ─── Wishlist Price Alerts ───────────────────────────────────────────────────

model PriceAlert {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  targetPrice  Float
  isTriggered  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ─── Brand Follows ───────────────────────────────────────────────────────────

model BrandFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
}

// ─── SaaS / API Key Management ───────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  ownerEmail       String
  stripeCustomerId String?          @unique
  subscriptionId   String?
  tier             SubscriptionTier @default(FREE)
  isActive         Boolean          @default(true)
  apiKeys          ApiKey[]
  usageLogs        ApiUsageLog[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([ownerEmail])
}

model ApiKey {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keyHash     String        @unique
  keyPrefix   String
  label       String        @default("Default")
  scopes      String[]
  isActive    Boolean       @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  usageLogs   ApiUsageLog[]
  createdAt   DateTime      @default(now())

  @@index([tenantId])
  @@index([keyHash])
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeyId  String
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint  String
  method    String
  status    Int
  latencyMs Int
  timestamp DateTime @default(now())

  @@index([tenantId, timestamp])
  @@index([apiKeyId, timestamp])
}
